rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /games/{document=**} {
      allow read: if true;
      allow write: if true;
    }
    match /news/{document=**} {
      allow read: if true;
      allow write: if true;
    }
    match /site/{document=**} {
      allow read: if true;
      allow write: if true;
    }
  }
}
